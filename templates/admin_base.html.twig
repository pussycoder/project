                                    let dropdownOpen = false;
                                    if (menuBtn && menu) {
                                        menuBtn.addEventListener('click', function (e) {
                                            e.stopPropagation();
                                            menu.classList.toggle('hidden');
                                            dropdownOpen = !dropdownOpen;
