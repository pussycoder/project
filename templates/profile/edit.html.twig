{% extends 'admin_base.html.twig' %}

{% block title %}Edit Profile - SKADOOSH{% endblock %}
{% block page_title %}Edit Profile{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="text-2xl font-bold mb-6" style="color: #111827 !important;">Update Your Profile</h2>

        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

        <div>
            {{ form_label(form.username, null, {'label_attr': {'class': 'block text-sm font-bold mb-2', 'style': 'color: #111827 !important;'}}) }}
            {{ form_widget(form.username, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 bg-gray-100', 'style': 'color: #111827 !important;'}}) }}
            <p class="text-xs text-gray-600 mt-1">Username cannot be changed</p>
        </div>

        <div>
            {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-bold mb-2', 'style': 'color: #111827 !important;'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 bg-white focus:ring-2 focus:ring-red-500 focus:border-red-500', 'style': 'color: #111827 !important;'}}) }}
            {{ form_errors(form.email) }}
        </div>

        <div>
            {{ form_label(form.fullName, null, {'label_attr': {'class': 'block text-sm font-bold mb-2', 'style': 'color: #111827 !important;'}}) }}
            {{ form_widget(form.fullName, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 bg-white focus:ring-2 focus:ring-red-500 focus:border-red-500', 'style': 'color: #111827 !important;'}}) }}
            {{ form_errors(form.fullName) }}
        </div>

        <div>
            {{ form_label(form.plainPassword, null, {'label_attr': {'class': 'block text-sm font-bold mb-2', 'style': 'color: #111827 !important;'}}) }}
            {{ form_widget(form.plainPassword, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 bg-white focus:ring-2 focus:ring-red-500 focus:border-red-500', 'style': 'color: #111827 !important;'}}) }}
            <p class="text-xs text-gray-600 mt-1">Leave blank to keep your current password</p>
            {{ form_errors(form.plainPassword) }}
        </div>

        <div class="flex items-center justify-between pt-4">
            <a href="{{ path('app_profile_show') }}" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold rounded-lg transition-colors">
                Cancel
            </a>
            <button type="submit" class="px-6 py-2 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg transition-all transform hover:scale-105">
                Save Changes
            </button>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

