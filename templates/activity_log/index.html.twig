{% extends 'admin_base.html.twig' %}

{% block title %}Activity Logs - SKADOOSH{% endblock %}
{% block page_title %}Activity Logs{% endblock %}
{% block breadcrumb_items %}
    <span style="color: #334155; font-weight: 500;">Activity Logs</span>
{% endblock %}

{% block body %}
<div class="space-y-6">
    <!-- Header Section - TailAdmin Style -->
    <div class="bg-gradient-to-r from-[#7a0000] via-[#8a0000] to-[#9a0000] rounded-xl p-6 sm:p-8 text-white mb-6 shadow-xl">
        <h1 class="text-3xl sm:text-4xl font-bold mb-2" style="color: #ffffff !important; font-weight: 800; letter-spacing: -0.02em;">Activity Logs</h1>
        <p class="text-base sm:text-lg" style="color: rgba(255, 255, 255, 0.95) !important; font-weight: 400;">View all system activities and user actions</p>
    </div>

    <!-- Filters Section -->
    <div class="card p-6 mb-6">
        <h2 class="text-lg font-bold mb-4" style="color: #0f172a !important; font-weight: 700;">Filter Logs</h2>
        <form method="GET" action="{{ path('app_activity_log_index') }}" class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-2" style="color: #1e293b !important; font-weight: 600;">Action</label>
                <select name="action" class="w-full border-1.5 rounded-lg p-3 focus:ring-2 focus:ring-[#7a0000] focus:border-[#7a0000]" style="color: #0f172a !important; font-weight: 500; background-color: #ffffff !important; border-color: #cbd5e1 !important;">
                    <option value="" style="color: #0f172a !important; background: #ffffff !important;">All Actions</option>
                    <option value="Login" {{ currentAction == 'Login' ? 'selected' : '' }} style="color: #0f172a !important; background: #ffffff !important;">Login</option>
                    <option value="Logout" {{ currentAction == 'Logout' ? 'selected' : '' }} style="color: #0f172a !important; background: #ffffff !important;">Logout</option>
                    <option value="Create" {{ currentAction == 'Create' ? 'selected' : '' }} style="color: #0f172a !important; background: #ffffff !important;">Create</option>
                    <option value="Update" {{ currentAction == 'Update' ? 'selected' : '' }} style="color: #0f172a !important; background: #ffffff !important;">Update</option>
                    <option value="Delete" {{ currentAction == 'Delete' ? 'selected' : '' }} style="color: #0f172a !important; background: #ffffff !important;">Delete</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2" style="color: #1e293b !important; font-weight: 600;">User</label>
                <select name="user" class="w-full border-1.5 rounded-lg p-3 focus:ring-2 focus:ring-[#7a0000] focus:border-[#7a0000]" style="color: #0f172a !important; font-weight: 500; background-color: #ffffff !important; border-color: #cbd5e1 !important;">
                    <option value="" style="color: #0f172a !important; background: #ffffff !important;">All Users</option>
                    {% for u in users %}
                        <option value="{{ u.id }}" {% if currentUser and currentUser == u.id %}selected{% endif %} style="color: #0f172a !important; background: #ffffff !important;">
                            {{ u.fullName ?: u.username }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2" style="color: #1e293b !important; font-weight: 600;">Date</label>
                <input type="date" name="date" value="{{ currentDate }}" class="w-full border-1.5 rounded-lg p-3 focus:ring-2 focus:ring-[#7a0000] focus:border-[#7a0000]" style="color: #0f172a !important; font-weight: 500; background-color: #ffffff !important; border-color: #cbd5e1 !important;">
            </div>
            <div class="flex items-end">
                <button type="submit" class="btn-primary w-full px-4 py-3">
                    Apply Filters
                </button>
            </div>
        </form>
        {% if currentAction or currentUser or currentDate %}
        <div class="mt-4">
            <a href="{{ path('app_activity_log_index') }}" class="text-sm font-semibold transition-colors" style="color: #7a0000 !important; font-weight: 600;">
                Clear All Filters
            </a>
        </div>
        {% endif %}
    </div>

    <!-- Activity Logs Table -->
    <div class="card overflow-hidden">
        <table id="activityLogsTable" class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gradient-to-r from-[#7a0000] via-[#8a0000] to-[#9a0000]">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold text-white uppercase tracking-wider cursor-pointer hover:bg-red-800" style="color: #ffffff !important;">User ID</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-white uppercase tracking-wider cursor-pointer hover:bg-red-800" style="color: #ffffff !important;">Username</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-white uppercase tracking-wider cursor-pointer hover:bg-red-800" style="color: #ffffff !important;">Role</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-white uppercase tracking-wider cursor-pointer hover:bg-red-800" style="color: #ffffff !important;">Action</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-white uppercase tracking-wider cursor-pointer hover:bg-red-800" style="color: #ffffff !important;">Target Data</th>
                        <th class="px-6 py-3 text-left text-xs font-bold text-white uppercase tracking-wider cursor-pointer hover:bg-red-800" style="color: #ffffff !important;">Date & Time</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for log in logs %}
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold" style="color: #0f172a !important; font-weight: 600;">
                            {{ log.user.id }}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm font-bold" style="color: #0f172a !important; font-weight: 700;">
                                {{ log.user.username }}
                            </div>
                            {% if log.user.fullName %}
                            <div class="text-xs" style="color: #64748b !important; font-weight: 400;">{{ log.user.fullName }}</div>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            {% if log.role == 'ROLE_ADMIN' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #ede9fe !important; color: #6b21a8 !important; font-weight: 600;">
                                    Admin
                                </span>
                            {% elseif log.role == 'ROLE_STAFF' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #dbeafe !important; color: #1e40af !important; font-weight: 600;">
                                    Staff
                                </span>
                            {% else %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #d1fae5 !important; color: #065f46 !important; font-weight: 600;">
                                    User
                                </span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap">
                            {% if log.action == 'Login' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #d1fae5 !important; color: #065f46 !important; font-weight: 600;">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-8.707l-3-3a1 1 0 00-1.414 0l-3 3a1 1 0 001.414 1.414L9 9.414V13a1 1 0 102 0V9.414l1.293 1.293a1 1 0 001.414-1.414z" clip-rule="evenodd"/>
                                    </svg>
                                    Login
                                </span>
                            {% elseif log.action == 'Logout' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #fee2e2 !important; color: #991b1b !important; font-weight: 600;">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                    Logout
                                </span>
                            {% elseif log.action == 'Create' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #dbeafe !important; color: #1e40af !important; font-weight: 600;">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd"/>
                                    </svg>
                                    Create
                                </span>
                            {% elseif log.action == 'Update' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #fef3c7 !important; color: #92400e !important; font-weight: 600;">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/>
                                    </svg>
                                    Update
                                </span>
                            {% elseif log.action == 'Delete' %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #fee2e2 !important; color: #991b1b !important; font-weight: 600;">
                                    <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"/>
                                    </svg>
                                    Delete
                                </span>
                            {% else %}
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium" style="background: #f3f4f6 !important; color: #374151 !important; font-weight: 600;">
                                    {{ log.action }}
                                </span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            {% if log.entityType and log.entityId %}
                                <div class="font-semibold" style="color: #0f172a !important; font-weight: 600;">{{ log.entityType }}: {{ log.description|split(':')|last|trim }}</div>
                                <div class="text-xs" style="color: #64748b !important; font-weight: 400;">ID: {{ log.entityId }}</div>
                            {% elseif log.description %}
                                <div class="font-semibold" style="color: #0f172a !important; font-weight: 600;">{{ log.description }}</div>
                            {% else %}
                                <span style="color: #94a3b8 !important;">-</span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <div class="font-semibold" style="color: #0f172a !important; font-weight: 600;">{{ log.createdAt|date('Y-m-d') }}</div>
                            <div class="text-xs" style="color: #64748b !important; font-weight: 400;">{{ log.createdAt|date('g:i:s A') }}</div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center">
                            <svg class="mx-auto h-12 w-12 mb-4" style="color: #94a3b8;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                            <h3 class="mt-2 text-sm font-medium" style="color: #0f172a !important; font-weight: 600;">No activity logs</h3>
                            <p class="mt-1 text-sm" style="color: #64748b !important; font-weight: 400;">Activity logs will appear here as users interact with the system.</p>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
    </div>

    <script>
        $(document).ready(function() {
            if (document.getElementById('activityLogsTable')) {
                $('#activityLogsTable').DataTable({
                    order: [[5, 'desc']], // Sort by Date & Time column (6th column, index 5) in descending order
                    pageLength: 25,
                    lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                    language: {
                        search: "Search:",
                        lengthMenu: "Show _MENU_ entries",
                        info: "Showing _START_ to _END_ of _TOTAL_ entries",
                        infoEmpty: "Showing 0 to 0 of 0 entries",
                        infoFiltered: "(filtered from _MAX_ total entries)",
                        zeroRecords: "No matching records found",
                        paginate: {
                            first: "First",
                            last: "Last",
                            next: "Next",
                            previous: "Previous"
                        }
                    },
                    dom: '<"flex flex-col sm:flex-row sm:items-center sm:justify-between mb-4"<"flex items-center space-x-2"l><"flex items-center space-x-2"f>>rt<"flex flex-col sm:flex-row sm:items-center sm:justify-between mt-4"<"flex items-center"i><"flex items-center space-x-2"p>>',
                    initComplete: function() {
                        // AGGRESSIVE - Make ALL DataTables text visible
                        $('.dataTables_wrapper *').css({
                            'color': '#0f172a !important'
                        });
                        
                        // Make DataTables controls visible
                        $('.dataTables_length select').css({
                            'color': '#0f172a !important',
                            'background-color': '#ffffff !important',
                            'font-weight': '600',
                            'border': '1.5px solid #cbd5e1'
                        });
                        $('.dataTables_length select option').css({
                            'color': '#0f172a !important',
                            'background-color': '#ffffff !important',
                            'font-weight': '500'
                        });
                        // Make "Show entries" label visible - AGGRESSIVE
                        $('.dataTables_length').css({
                            'color': '#0f172a !important'
                        });
                        $('.dataTables_length *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_length label').css({
                            'color': '#0f172a !important',
                            'font-weight': '700 !important'
                        });
                        $('.dataTables_length span, .dataTables_length div, .dataTables_length p').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_filter input').css({
                            'color': '#0f172a !important',
                            'background-color': '#ffffff !important',
                            'font-weight': '600',
                            'border': '1.5px solid #cbd5e1'
                        });
                        // Make "Search:" label visible - AGGRESSIVE
                        $('.dataTables_filter').css({
                            'color': '#0f172a !important'
                        });
                        $('.dataTables_filter *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_filter label').css({
                            'color': '#0f172a !important',
                            'font-weight': '700 !important'
                        });
                        $('.dataTables_info').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_info *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_paginate a').css({
                            'color': '#7a0000 !important',
                            'font-weight': '600'
                        });
                        // Make all text in flex containers visible - AGGRESSIVE
                        $('.dataTables_wrapper .flex, .dataTables_wrapper [class*="flex"]').css({
                            'color': '#0f172a !important'
                        });
                        $('.dataTables_wrapper .flex *, .dataTables_wrapper [class*="flex"] *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_wrapper .flex label, .dataTables_wrapper [class*="flex"] label').css({
                            'color': '#0f172a !important',
                            'font-weight': '700'
                        });
                    },
                    drawCallback: function() {
                        // AGGRESSIVE - Force ALL text visible on every draw
                        $('.dataTables_wrapper *:not(.dataTables_paginate a):not(.paginate_button a)').css({
                            'color': '#0f172a !important'
                        });
                        
                        // Ensure dropdown colors are visible on every draw
                        $('.dataTables_length select').css({
                            'color': '#0f172a !important',
                            'background-color': '#ffffff !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_length select option').css({
                            'color': '#0f172a !important',
                            'background-color': '#ffffff !important',
                            'font-weight': '500'
                        });
                        // Ensure "Show entries" label is visible on every draw - AGGRESSIVE
                        $('.dataTables_length').css({
                            'color': '#0f172a !important'
                        });
                        $('.dataTables_length *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_length label').css({
                            'color': '#0f172a !important',
                            'font-weight': '700 !important'
                        });
                        $('.dataTables_length span, .dataTables_length div, .dataTables_length p').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_filter input').css({
                            'color': '#0f172a !important',
                            'background-color': '#ffffff !important',
                            'font-weight': '600'
                        });
                        // Ensure "Search:" label is visible on every draw - AGGRESSIVE
                        $('.dataTables_filter').css({
                            'color': '#0f172a !important'
                        });
                        $('.dataTables_filter *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_filter label').css({
                            'color': '#0f172a !important',
                            'font-weight': '700 !important'
                        });
                        $('.dataTables_info').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_info *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_paginate a').css({
                            'color': '#7a0000 !important',
                            'font-weight': '600'
                        });
                        // Ensure all text in flex containers is visible on every draw - AGGRESSIVE
                        $('.dataTables_wrapper .flex, .dataTables_wrapper [class*="flex"]').css({
                            'color': '#0f172a !important'
                        });
                        $('.dataTables_wrapper .flex *, .dataTables_wrapper [class*="flex"] *').css({
                            'color': '#0f172a !important',
                            'font-weight': '600'
                        });
                        $('.dataTables_wrapper .flex label, .dataTables_wrapper [class*="flex"] label').css({
                            'color': '#0f172a !important',
                            'font-weight': '700'
                        });
                    }
                });
            }
        });
    </script>

    <!-- Info Box -->
    <div class="bg-blue-50 border-2 border-blue-200 rounded-xl p-4 shadow-sm" style="background:rgb(98, 117, 143) !important; border-color: #bfdbfe !important;">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5" style="color: #ffffff !important;" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="ml-3">
                <h3 class="text-sm font-bold" style="color: #ffffff !important; font-weight: 700;">Activity Log Information</h3>
                <div class="mt-2 text-sm" style="color: #f8fafc !important; font-weight: 400;">
                    <p><strong style="color: #ffffff !important; font-weight: 700;">Read-Only:</strong> Activity logs are read-only and cannot be modified.</p>
                    <p class="mt-1"><strong style="color: #ffffff !important; font-weight: 700;">Required Fields:</strong> Each log contains User ID, Username, Role, Action, Target Data, and Date/Time.</p>
                    <p class="mt-1"><strong style="color: #ffffff !important; font-weight: 700;">Access:</strong> Only administrators can view these logs. Staff members cannot access this page.</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

