{% extends 'base.html.twig' %}
{% block title %}Hello PageController!{% endblock %}

{% block body %}

<section>
    <div class="container mx-auto">
        <div class="navbar bg-base-100 shadow-sm flex justify-between items-center">
            <div class="flex-1">
                <a class="btn btn-ghost">
                <img src="/Logo.png" alt="Logo" style="height:80px;"</a>
            </div>
            <div class="flex-none flex items-center gap-4">
                <div class="dropdown dropdown-end">
                    <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
                        <div class="indicator">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                            <span class="badge badge-sm indicator-item">8</span>
                        </div>
                    </div>
                    <div tabindex="0" class="card card-compact dropdown-content bg-base-100 z-1 mt-3 w-52 shadow">
                        <div class="card-body">
                            <span class="text-lg font-bold">8 Items</span>
                            <span class="text-info">Subtotal: $999</span>
                            <div class="card-actions">
                                <button class="btn btn-primary btn-block">View cart</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="dropdown dropdown-end">
                    <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
                        <div class="w-10 rounded-full">
                            <img alt="profile picture" src="/profile icon.jpg" />
                        </div>
                    </div>
                    <ul tabindex="0" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-52 p-2 shadow">
                        <li>
                            <a class="justify-between">
                                Profile
                                <span class="badge">New</span>
                            </a>
                        </li>
                        <li><a>Settings</a></li>
                        <li><a>Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <header class="my-8 text-center flex flex-col items-center">
            <h1 class="text-4xl font-bold mb-2">Welcome to SKADOOSH Apparel</h1>
            <p class="text-lg text-gray-600 max-w-xl">Discover the latest trends and timeless styles. Shop quality for every occasion.</p>
        </header>
            <div class="carousel carousel-center w-full h-[600px] rounded-box mb-8">
            <div class="carousel-item w-full">
                <img src="/Pattern.png" alt="Pattern" class="w-full object-cover" />
            </div>
            <div class="carousel-item w-full">
                <img src="/Pattern.png" alt="Pattern" class="w-full object-cover" />
            </div>
            <div class="carousel-item w-full">
                <img src="/Pattern2.png" alt="Apparel" class="w-full object-cover" />
            </div>
        </div>
        </div>
            <script>
            document.addEventListener('DOMContentLoaded', function() {
                const carousel = document.querySelector('.carousel');
                if (carousel) {
                    let isDown = false;
                    let startX;
                    let scrollLeft;

                    carousel.addEventListener('mousedown', (e) => {
                        isDown = true;
                        carousel.classList.add('active');
                        startX = e.pageX - carousel.offsetLeft;
                        scrollLeft = carousel.scrollLeft;
                    });

                    carousel.addEventListener('mouseleave', () => {
                        isDown = false;
                        carousel.classList.remove('active');
                    });

                    carousel.addEventListener('mouseup', () => {
                        isDown = false;
                        carousel.classList.remove('active');
                    });

                    carousel.addEventListener('mousemove', (e) => {
                        if (!isDown) return;
                        e.preventDefault();
                        const x = e.pageX - carousel.offsetLeft;
                        const walk = (x - startX) * 2;
                        carousel.scrollLeft = scrollLeft - walk;
                    });
                }
            });
            </script>
        </div>
    </div>
</section>
{% endblock %}