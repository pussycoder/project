{% extends 'base.html.twig' %}
{% block title %}SKADOOSH - Premium Apparel{% endblock %}

{% block stylesheets %}
<style>
    body {
        background-image: url('{{ asset('Pattern.png') }}') !important;
        background-size: cover !important;
        background-position: center !important;
        background-repeat: no-repeat !important;
        background-attachment: fixed !important;
        background-color: transparent !important;
    }
    
    /* Make main container fully transparent to show pattern */
    main {
        background-color: transparent !important;
        box-shadow: none !important;
    }
    
    /* Override the inner div in main */
    main > div {
        background-color: transparent !important;
    }
    
    /* Make sections transparent */
    section {
        background-color: transparent !important;
    }
    
    /* Make carousel background more transparent */
    .carousel {
        background-color: rgba(255, 255, 255, 0.5) !important;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    
    .carousel::-webkit-scrollbar {
        display: none;
    }
    
    .carousel-dot.active {
        background-color: #dc2626;
        width: 2rem;
    }
    
    /* Make feature cards more transparent to show pattern */
    article {
        background-color: rgba(255, 255, 255, 0.6) !important;
    }
    
    /* Ensure text is readable on pattern background */
    h1, h2, h3, h4, h5, h6, p, span {
        text-shadow: 0 1px 2px rgba(255, 255, 255, 0.8);
    }
</style>
{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="text-center mb-12 sm:mb-16">
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-4" style="color: #7a0000 !important;">
        Welcome to SKADOOSH
    </h1>
    <p class="text-lg sm:text-xl text-gray-700 max-w-2xl mx-auto mb-8" style="color: #374151 !important;">
        Discover the latest trends and timeless styles. Shop quality apparel for every occasion.
    </p>
    {% if not app.user %}
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="{{ path('app_register') }}" class="inline-flex items-center justify-center px-8 py-3 bg-red-600 hover:bg-red-700 text-white font-bold rounded-xl shadow-lg transition-all transform hover:scale-105 active:scale-95">
            Get Started
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
        </a>
        <a href="{{ path('app_login') }}" class="inline-flex items-center justify-center px-8 py-3 bg-white hover:bg-gray-50 text-red-600 font-bold rounded-xl shadow-lg border-2 border-red-600 transition-all transform hover:scale-105 active:scale-95">
            Sign In
        </a>
    </div>
    {% endif %}
</section>

<!-- Image Carousel -->
<section class="mb-12 sm:mb-16">
    <div class="carousel overflow-hidden rounded-2xl shadow-2xl p-4 sm:p-6 flex overflow-x-auto scroll-smooth" style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
        <img src="{{ asset('1.png') }}" alt="SKADOOSH Apparel Collection 1" class="carousel-item flex-shrink-0 w-full h-64 sm:h-96 lg:h-[500px] object-contain rounded-xl transition-transform duration-300 hover:scale-105" style="scroll-snap-align: center;" />
        <img src="{{ asset('1.png') }}" alt="SKADOOSH Apparel Collection 2" class="carousel-item flex-shrink-0 w-full h-64 sm:h-96 lg:h-[500px] object-contain rounded-xl transition-transform duration-300 hover:scale-105" style="scroll-snap-align: center;" />
        <img src="{{ asset('2.png') }}" alt="SKADOOSH Apparel Collection 3" class="carousel-item flex-shrink-0 w-full h-64 sm:h-96 lg:h-[500px] object-contain rounded-xl transition-transform duration-300 hover:scale-105" style="scroll-snap-align: center;" />
    </div>
    
    <!-- Carousel Navigation Dots -->
    <div class="flex justify-center mt-6 space-x-2">
        <button class="carousel-dot w-3 h-3 rounded-full bg-red-600 transition-all" data-slide="0"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 hover:bg-gray-400 transition-all" data-slide="1"></button>
        <button class="carousel-dot w-3 h-3 rounded-full bg-gray-300 hover:bg-gray-400 transition-all" data-slide="2"></button>
    </div>
</section>

<!-- Features Section -->
<section class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8 mb-12">
    <article class="rounded-xl p-6 shadow-lg border border-gray-200 text-center hover:shadow-xl transition-shadow">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
        </div>
        <h3 class="text-xl font-bold mb-2" style="color: #111827 !important;">Premium Quality</h3>
        <p class="text-gray-600" style="color: #6b7280 !important;">Crafted with attention to detail and premium materials</p>
    </article>
    
    <article class="rounded-xl p-6 shadow-lg border border-gray-200 text-center hover:shadow-xl transition-shadow">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <h3 class="text-xl font-bold mb-2" style="color: #111827 !important;">Best Prices</h3>
        <p class="text-gray-600" style="color: #6b7280 !important;">Competitive pricing without compromising on quality</p>
    </article>
    
    <article class="rounded-xl p-6 shadow-lg border border-gray-200 text-center hover:shadow-xl transition-shadow">
        <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
        </div>
        <h3 class="text-xl font-bold mb-2" style="color: #111827 !important;">Fast Delivery</h3>
        <p class="text-gray-600" style="color: #6b7280 !important;">Quick and reliable shipping to your doorstep</p>
    </article>
</section>

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const carousel = document.querySelector('.carousel');
        const dots = document.querySelectorAll('.carousel-dot');
        let currentSlide = 0;
        let isDown = false;
        let startX;
        let scrollLeft;
        
        // Auto-play carousel
        function nextSlide() {
            currentSlide = (currentSlide + 1) % 3;
            updateCarousel();
        }
        
        function updateCarousel() {
            carousel.scrollTo({
                left: currentSlide * carousel.offsetWidth,
                behavior: 'smooth'
            });
            dots.forEach((dot, index) => {
                if (index === currentSlide) {
                    dot.classList.add('active', 'bg-red-600');
                    dot.classList.remove('bg-gray-300');
                } else {
                    dot.classList.remove('active', 'bg-red-600');
                    dot.classList.add('bg-gray-300');
                }
            });
        }
        
        // Dot navigation
        dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
                currentSlide = index;
                updateCarousel();
            });
        });
        
        // Auto-play every 5 seconds
        setInterval(nextSlide, 5000);
        
        // Touch/swipe support
        carousel.addEventListener('mousedown', (e) => {
            isDown = true;
            startX = e.pageX - carousel.offsetLeft;
            scrollLeft = carousel.scrollLeft;
        });
        
        carousel.addEventListener('mouseleave', () => {
            isDown = false;
        });
        
        carousel.addEventListener('mouseup', () => {
            isDown = false;
        });
        
        carousel.addEventListener('mousemove', (e) => {
            if (!isDown) return;
            e.preventDefault();
            const x = e.pageX - carousel.offsetLeft;
            const walk = (x - startX) * 2;
            carousel.scrollLeft = scrollLeft - walk;
        });
    });
</script>
{% endblock %}
{% endblock %}
