{% extends 'admin_base.html.twig' %}
{% block title %}Products - SKADOOSH{% endblock %}
{% block page_title %}Products Management{% endblock %}
{% block breadcrumb_items %}
    <span>Products</span>
{% endblock %}

{% block body %}
<div class="space-y-6">
    <!-- Header Section - TailAdmin Style -->
    <div class="bg-gradient-to-r from-[#7a0000] via-[#8a0000] to-[#9a0000] rounded-xl p-6 sm:p-8 text-white mb-6 shadow-xl">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
            <div class="mb-4 sm:mb-0">
                <h1 class="text-3xl sm:text-4xl font-bold mb-2" style="color: #ffffff !important; font-weight: 800; letter-spacing: -0.02em;">Products</h1>
                <p class="text-base sm:text-lg" style="color: rgba(255, 255, 255, 0.95) !important; font-weight: 400;">Manage your product inventory</p>
            </div>
            <div class="mt-4 sm:mt-0">
                <a href="{{ path('app_products_new') }}" class="inline-flex items-center px-6 py-3 bg-white text-[#7a0000] font-bold rounded-lg shadow-lg hover:bg-gray-50 transition-all transform hover:scale-105 active:scale-95" style="color: #7a0000 !important; font-weight: 600; font-family: 'Inter', sans-serif !important;">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                    </svg>
                    Add Product
                </a>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="bg-white dark:bg-slate-800 rounded-xl p-4 sm:p-6 shadow-md border border-gray-200 dark:border-slate-700 mb-6">
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <div class="flex-1">
                <div class="relative">
                    <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                    <input id="product-search" type="text" placeholder="Search products..." class="w-full pl-10 pr-4 py-3 border-2 border-gray-200 dark:border-slate-600 rounded-xl bg-white dark:bg-slate-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all font-medium" style="color: #111827 !important;">
                </div>
            </div>
            <div class="flex gap-2">
                <select id="filter-category" class="px-4 py-3 border-2 border-gray-200 dark:border-slate-600 rounded-xl bg-white dark:bg-slate-700 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all font-medium" style="color: #111827 !important; background-color: #ffffff !important;">
                    <option value="all">All Categories</option>
                    <option value="shirts">Shirts</option>
                    <option value="accessories">Accessories</option>
                </select>
                <select id="sort-by" class="px-4 py-3 border-2 border-gray-200 dark:border-slate-600 rounded-xl bg-white dark:bg-slate-700 focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all font-medium" style="color: #111827 !important; background-color: #ffffff !important;">
                    <option value="none">Sort by</option>
                    <option value="name-asc">Name A-Z</option>
                    <option value="name-desc">Name Z-A</option>
                    <option value="price-asc">Price Low-High</option>
                    <option value="price-desc">Price High-Low</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Products Grid -->
    <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
        {% for product in products %}
        <div class="product-card bg-white dark:bg-slate-800 rounded-xl shadow-md border border-gray-200 dark:border-slate-700 overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
             data-name="{{ product.name|lower }}"
             data-category="{{ product.category ? product.category.name|lower : 'no category' }}"
             data-price="{{ product.price }}">
            <!-- Product Image -->
            <div class="relative h-48 bg-gray-100 dark:bg-slate-700">
                {% if product.image %}
                    <img src="{{ asset('uploads/images/' ~ product.image) }}" 
                         alt="{{ product.name }}" 
                         class="w-full h-full object-cover">
                {% else %}
                    <div class="w-full h-full flex items-center justify-center">
                        <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                {% endif %}
                
                <!-- Status Badge -->
                <div class="absolute top-3 right-3">
                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300">
                        Active
                    </span>
                </div>
            </div>

            <!-- Product Info -->
            <div class="p-4">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{{ product.name }}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">{{ product.category ? product.category.name : 'No Category' }}</p>
                
                <div class="flex items-center justify-between mb-4">
                    <span class="text-xl font-bold" style="color: #dc2626 !important;">₱{{ product.price|number_format(2, '.', ',') }}</span>
                    <div class="flex items-center text-sm text-gray-500 dark:text-gray-400">
                        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                        </svg>
                        In Stock
                    </div>
                </div>

                <!-- Actions -->
                <div class="flex gap-2">
                    <a href="{{ path('app_products_show', {'id': product.id}) }}" class="flex-1 inline-flex items-center justify-center px-4 py-2.5 border-2 border-gray-200 dark:border-slate-600 text-sm font-semibold rounded-xl text-gray-700 dark:text-gray-300 bg-white dark:bg-slate-700 hover:bg-gray-50 dark:hover:bg-slate-600 transition-all transform hover:scale-105 active:scale-95" style="color: #111827 !important;">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                        View
                    </a>
                    <a href="{{ path('app_products_edit', {'id': product.id}) }}" class="flex-1 inline-flex items-center justify-center px-4 py-2.5 bg-gradient-to-r from-red-600 to-red-700 hover:from-red-700 hover:to-red-800 text-white text-sm font-bold rounded-xl transition-all transform hover:scale-105 active:scale-95 shadow-md hover:shadow-lg">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Edit
                    </a>
                </div>
            </div>
        </div>
        {% else %}
        <!-- Empty State -->
        <div class="col-span-full">
            <div class="text-center py-12">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No products</h3>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by creating a new product.</p>
                <div class="mt-6">
                    <a href="{{ path('app_products_new') }}" class="inline-flex items-center px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-medium rounded-lg transition-colors">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                        </svg>
                        Add Product
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <script>
        (function(){
            const search = document.getElementById('product-search');
            const category = document.getElementById('filter-category');
            const sort = document.getElementById('sort-by');
            const grid = document.getElementById('products-grid');
            if (!grid) return;

            // capture initial elements
            const allCards = Array.from(grid.querySelectorAll('.product-card'));

            function debounce(fn, wait = 180) {
                let timer;
                return function(...args) {
                    clearTimeout(timer);
                    timer = setTimeout(() => fn.apply(this, args), wait);
                };
            }

            function applyFilters() {
                const q = (search && search.value ? search.value.trim().toLowerCase() : '');
                const cat = (category && category.value ? category.value.toLowerCase() : 'all');
                const sortVal = (sort && sort.value) ? sort.value : 'none';

                let filtered = allCards.filter(card => {
                    const name = (card.dataset.name || '').toLowerCase();
                    const c = (card.dataset.category || '').toLowerCase();
                    const matchesQ = !q || name.includes(q);
                    const matchesCat = cat === 'all' || c === cat;
                    return matchesQ && matchesCat;
                });

                filtered.sort((a,b) => {
                    if (sortVal === 'name-asc') return a.dataset.name.localeCompare(b.dataset.name);
                    if (sortVal === 'name-desc') return b.dataset.name.localeCompare(a.dataset.name);
                    if (sortVal === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
                    if (sortVal === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
                    return 0;
                });

                // render
                grid.innerHTML = '';
                filtered.forEach(c => grid.appendChild(c));
            }

            const debouncedApply = debounce(applyFilters, 180);

            if (search) search.addEventListener('input', debouncedApply);
            if (category) category.addEventListener('change', applyFilters);
            if (sort) sort.addEventListener('change', applyFilters);

            // Listen for forwarded topbar global search
            document.addEventListener('global-search', (e) => {
                if (!search) return;
                search.value = e.detail || '';
                debouncedApply();
            });

            applyFilters();
        })();
    </script>

    <!-- Pagination -->
    {% if products|length > 0 %}
    <div class="flex items-center justify-between">
        <div class="text-sm text-gray-700 dark:text-gray-300">
            Showing <span class="font-medium">1</span> to <span class="font-medium">{{ products|length }}</span> of <span class="font-medium">{{ products|length }}</span> results
        </div>
        <div class="flex items-center space-x-2">
            <button class="px-3 py-2 text-sm font-medium text-gray-500 dark:text-gray-400 bg-white dark:bg-slate-800 border border-gray-300 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                Previous
            </button>
            <button class="px-3 py-2 text-sm font-medium text-gray-900 dark:text-white bg-red-600 border border-transparent rounded-lg">
                1
            </button>
            <button class="px-3 py-2 text-sm font-medium text-gray-500 dark:text-gray-400 bg-white dark:bg-slate-800 border border-gray-300 dark:border-slate-600 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-700 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                Next
            </button>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}