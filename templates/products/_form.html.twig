{{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'space-y-6'}}) }}

    {# ✅ Global form errors #}
    {% if form_errors(form) %}
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    {# ✅ Product Name #}
    <div>
        <label class="block text-sm font-bold text-gray-900 mb-2">Name <span class="text-red-600">*</span></label>
        {{ form_widget(form.name, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 font-medium'}}) }}
        {% if form_errors(form.name) %}
            <p class="text-xs text-red-600 mt-1">{{ form_errors(form.name) }}</p>
        {% endif %}
    </div>

    {# ✅ Description #}
    <div>
        <label class="block text-sm font-bold text-gray-900 mb-2">Description <span class="text-red-600">*</span></label>
        {{ form_widget(form.description, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 font-medium', 'rows': 4}}) }}
        {% if form_errors(form.description) %}
            <p class="text-xs text-red-600 mt-1">{{ form_errors(form.description) }}</p>
        {% endif %}
    </div>

    {# ✅ Price #}
    <div>
        <label class="block text-sm font-bold text-gray-900 mb-2">Price <span class="text-red-600">*</span></label>
        {{ form_widget(form.price, {'attr': {'class': 'w-full border-2 border-gray-300 rounded-lg p-3 text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 font-medium'}}) }}
        {% if form_errors(form.price) %}
            <p class="text-xs text-red-600 mt-1">{{ form_errors(form.price) }}</p>
        {% endif %}
    </div>

    {# ✅ Image Upload #}
    <div>
        <label class="block text-sm font-bold text-gray-900 mb-2">Upload Image</label>
        {{ form_widget(form.image, {'attr': {'class': 'block w-full text-sm text-gray-900 border-2 border-gray-300 rounded-lg cursor-pointer bg-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 font-medium'}}) }}
        <p class="text-xs text-gray-500 mt-1">Accepted formats: JPG, PNG | Max size: 2MB</p>

        {% if form_errors(form.image) %}
            <p class="text-xs text-red-600 mt-1">{{ form_errors(form.image) }}</p>
        {% endif %}

        {# ✅ Show current image only when editing (to avoid array-to-string error) #}
        {% if product is defined and product.image %}
            <div class="mt-4 text-center">
                <img src="{{ asset('uploads/images/' ~ product.image) }}" alt="Current image" class="rounded-lg shadow-md w-40 h-40 object-cover mx-auto">
            </div>
        {% endif %}
    </div>

    {# ✅ Category Dropdown #}
    <div>
        <label class="block text-sm font-bold text-gray-900 mb-2">Category</label>
        {{ form_widget(form.category, {
            'attr': {
                'class': 'w-full border-2 border-gray-300 rounded-lg p-3 text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 font-medium'
            }
        }) }}
        {% if form_errors(form.category) %}
            <p class="text-xs text-red-600 mt-1">{{ form_errors(form.category) }}</p>
        {% endif %}
    </div>

    {{ form_rest(form) }}

    <button class="w-full bg-gradient-to-r from-red-600 to-red-800 text-white font-bold py-3 px-4 rounded-lg shadow-lg hover:from-red-700 hover:to-red-900 transition-all transform hover:scale-[1.02] text-lg">
        {{ button_label|default('Save') }}
    </button>
{{ form_end(form) }}
