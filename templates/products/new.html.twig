{% extends 'base.html.twig' %}

{% block title %}New Product{% endblock %}

{% block body %}
<style>
    body {
        background-image: url('{{ asset('Pattern.png') }}');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        margin: 0;
        padding: 0;
        font-family: 'Maharlika', 'Georgia', serif;
        color: #1f2937;
    }

    /* Keep navbar readable */
    nav.navbar {
        position: relative;
        z-index: 10;
        background-color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
    }

    .form-wrapper {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        min-height: calc(100vh - 120px);
        padding: 60px 20px;
    }

    .form-container {
        width: 100%;
        max-width: 700px;
        background: rgba(255, 255, 255, 0.96);
        padding: 2.5rem;
        border-radius: 1rem;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        border-top: 6px solid #7a0000;
        backdrop-filter: blur(4px);
    }

    h1 {
        text-align: center;
        font-size: 2.2rem;
        color: #7a0000;
        font-weight: 800;
        margin-bottom: 1.8rem;
        letter-spacing: 0.5px;
    }

    form {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .form-group label {
        font-weight: 700;
        color: #111827;
        margin-bottom: 0.5rem;
        font-size: 1rem;
        display: block;
    }

    .form-control,
    select,
    input[type="text"],
    input[type="number"],
    input[type="file"],
    textarea {
        border: 2px solid #d1d5db;
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        width: 100%;
        transition: border-color 0.2s ease;
        background-color: #ffffff;
        color: #111827;
        font-size: 1rem;
        font-family: inherit;
    }

    .form-control:focus,
    select:focus,
    input:focus,
    textarea:focus {
        border-color: #7a0000;
        box-shadow: 0 0 0 3px rgba(122, 0, 0, 0.15);
        outline: none;
    }

    .button-group {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1.8rem;
    }

    .btn {
        display: inline-block;
        font-weight: 600;
        border-radius: 0.5rem;
        padding: 0.75rem 1.5rem;
        text-decoration: none;
        transition: 0.25s;
        cursor: pointer;
        border: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #7a0000, #a61a1a);
        color: #fff;
        box-shadow: 0 3px 6px rgba(0,0,0,0.1);
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, #a61a1a, #7a0000);
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    .btn-secondary {
        background: #f3f4f6;
        color: #374151;
    }

    .btn-secondary:hover {
        background: #e5e7eb;
        transform: translateY(-1px);
    }
    .file-upload {
        border: 2px dashed #ccc;
        border-radius: 10px;
        padding: 1rem;
        text-align: center;
        transition: 0.3s ease;
        cursor: pointer;
    }

    .file-upload:hover {
        border-color: #7a0000;
        background: #fff5f5;
    }

    .file-upload input[type="file"] {
        display: none;
    }

    .file-upload label {
        font-weight: 600;
        color: #7a0000;
        cursor: pointer;
    }

    .file-note {
        font-size: 0.9rem;
        color: #666;
        margin-top: 5px;
    }
</style>

<section class="form-wrapper">
    <div class="form-container">
        <h1>Add a New Product</h1>

        {{ include('products/_form.html.twig', {'button_label': 'Create Product'}) }}

        <div class="button-group">
            <a href="{{ path('app_products_index') }}" class="btn btn-secondary">
                ← Back to List
            </a>
        </div>
    </div>
</section>
{% endblock %}
